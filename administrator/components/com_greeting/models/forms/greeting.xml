<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="greeting_form">
        <field 
                name="id"
                type="hidden"
        />
        <field
            name="title"
            type="text"
            class="inputbox"
            label="COM_GREETING_NAME_LABEL"
            description="COM_GREETING_NAME_DESC"
            required="true"
        />
        <field
            name="message"
            type="textarea"
            class="inputbox"
            label="COM_GREETING_DETAIL_LABEL"
            description="COM_GREETING_DETAIL_DESC"
            required="true"
            rows="5"
        />
    </fieldset>
</form>